{
  "name": "tabsur",
  "version": "2.0.0",
  "description": "Tabsur - Social meal planning application",
  "main": "server.js",
  "scripts": {
    "client-install": "npm install --prefix client",
    "start": "node server.js",
    "server": "export NODE_ENV=production && nodemon server.js",
    "server-debug": "export NODE_ENV=debug && nodemon server.js",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "export NODE_ENV=production && npm run-script client-install && cd client && react-scripts build; cd ..",
    "stop": "node server.stop.js",
    "start-db": "docker-compose -p coolanu-db -f db/local-docker-compose.yaml up -d ",
    "stop-db": "docker-compose -p coolanu-db -f db/local-docker-compose.yaml down",
    "migrate-local-db": "bash ./db/migrate.sh",
    "debug": "concurrently \"npm run server-debug\" \"npm run client\"",
    "test-setup": "./test-mode.sh",
    "test-server": "export NODE_ENV=test && export DB_PORT=5433 && export DB_NAME=coolanu_test && nodemon server.js",
    "test-client": "cd client && REACT_APP_SERVER_HOST_DEV=http://localhost:5000 npm start",
    "test-dev": "concurrently \"npm run test-server\" \"npm run client\"",
    "test-cleanup": "./stop-test-mode.sh",
    "test": "cross-env NODE_ENV=test jest --testTimeout=30000",
    "test:fast": "cross-env NODE_ENV=test jest --config jest.config.fast.js",
    "test:unit": "cross-env NODE_ENV=test jest --config jest.config.fast.js --testPathPattern='tests/unit|tests/auth.test.js|tests/meals.test.js'",
    "test:watch": "cross-env NODE_ENV=test jest --config jest.config.fast.js --watch",
    "test:full": "./run-tests.sh",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --testTimeout=30000",
    "test:playwright": "playwright test --config=playwright.config.fast.js",
    "test:playwright:ui": "playwright test --config=playwright.config.fast.js --ui",
    "test:playwright:headed": "playwright test --config=playwright.config.fast.js --headed",
    "test:playwright:debug": "playwright test --config=playwright.config.fast.js --debug",
    "test:playwright:install": "playwright install",
    "test:playwright:install-deps": "playwright install-deps",
    "test:playwright:report": "playwright show-report",
    "lint": "npm run lint:server && npm run lint:client",
    "lint:fix": "npm run lint:fix:server && npm run lint:fix:client",
    "health": "node health-check.js",
    "lint:server": "npx eslint . --ext .js --ignore-pattern node_modules --ignore-pattern client",
    "lint:client": "cd client && npm run lint",
    "lint:fix:server": "npx eslint . --ext .js --ignore-pattern node_modules --ignore-pattern client --fix",
    "lint:fix:client": "cd client && npm run lint:fix",
    "security:audit": "npm audit --audit-level moderate",
    "security:fix": "npm audit fix",
    "ci:test": "npm run test:coverage",
    "ci:lint": "npm run lint",
    "ci:security": "npm run security:audit",
    "ci:build": "npm run build",
    "ci:full": "npm run ci:lint && npm run ci:test && npm run ci:security && npm run ci:build",
    "ci:install": "node scripts/suppress-security-warnings.js"
  },
  "author": "Mark&Yana",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.17.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "heroku-ssl-redirect": "0.0.4",
    "is-empty": "^1.2.0",
    "dompurify": "^3.4.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.3",
    "multiparty": "^4.2.1",
    "node-fetch": "^2.6.0",
    "pg": "^8.20.0",
    "validator": "^13.15.15"
  },
  "overrides": {
    "nth-check": "^2.1.1",
    "postcss": "^8.5.10",
    "@babel/runtime": "^7.26.10",
    "html-encoding-sniffer": "^4.0.0",
    "fast-xml-parser": "^5.7.0",
    "dompurify": "^3.4.0",
    "flatted": "^3.4.2",
    "brace-expansion": "^2.0.3",
    "lodash": "^4.18.1",
    "picomatch": "^4.0.0",
    "yaml": "^2.8.0",
    "node-forge": "^1.4.0",
    "path-to-regexp": "^0.1.13",
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "protobufjs": "^7.5.5",
    "underscore": "^1.13.8",
    "follow-redirects": "^1.16.0",
    "serialize-javascript": "^7.0.5",
    "@tootallnate/once": "^3.0.1",
    "jsonpath": "^1.3.0",
    "webpack-dev-server": "^5.2.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/komapc/tabsur"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.33.0",
    "@mui/material": "^7.3.11",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "axios": "^1.16.0",
    "babel-jest": "^30.0.5",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jsdom": "^24.0.0",
    "nodemon": "^3.1.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.1",
    "react-router-dom": "^7.15.0",
    "react-scripts": "^5.0.1",
    "redux-mock-store": "^1.5.5",
    "redux-thunk": "^3.1.0",
    "supertest": "^7.1.4"
  }
}
